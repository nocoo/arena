{
  "name": "arena",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "lint": "bun run --filter '*' lint",
    "dev": "bun run --cwd packages/web dev",
    "prepare": "husky"
  },
  "trustedDependencies": [
    "esbuild",
    "unrs-resolver"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bun": "^1.2.21",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "typescript-eslint": "^8.57.0"
  }
}
