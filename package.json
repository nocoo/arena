{
  "name": "arena",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "lint": "bun run --filter '*' lint",
    "dev": "bun run --cwd packages/web dev",
    "prepare": "husky",
    "typecheck": "tsc --noEmit"
  },
  "overrides": {
    "picomatch": "^4.0.4"
  },
  "trustedDependencies": [
    "better-sqlite3",
    "esbuild",
    "unrs-resolver"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bun": "^1.2.21",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "typescript-eslint": "^8.57.0"
  },
  "dependencies": {
    "picomatch": "^4.0.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0"
    ]
  }
}
